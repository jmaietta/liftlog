{
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://liftlog-90565.firebaseapp.com/__/auth/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}
